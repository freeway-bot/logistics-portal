# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Google Sheets — два источника данных ─────────────────────────────────────
# Scans (мелкие посылки): таблица 1IOJRUJpyVxmprDSf27lt01AiKJn7aAcKU-4H0pwuaNo
SCANS_SPREADSHEET_ID=your_scans_spreadsheet_id_here

# Логистика (отгрузки + пользователи): таблица 1OON0bdsWz1SmChhOBluoHa0p9BAlG3jIUs2XoyCHyYs
LOGISTICS_SPREADSHEET_ID=your_logistics_spreadsheet_id_here

# Вкладка с посылками (по умолчанию Scans!A:Z)
SHEET_RANGE=Scans!A:Z

# Вкладка с отправками в Scans-таблице
SHIPMENTS_SHEET_NAME=Shipments

# Вкладка с пользователями в Logistics-таблице
USERS_SHEET_NAME=Users

# ─── Google Service Account ─────────────────────────────────────────────────────
# Локальный запуск: путь к JSON-файлу
GOOGLE_KEY_FILE=./credentials/service-account.json

# Облачный деплой (Railway): вставить весь JSON одной строкой
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n..."}

# ─── Аутентификация ─────────────────────────────────────────────────────────────
# Секрет для JWT токенов. Сгенерировать: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-string

# ─── CORS ───────────────────────────────────────────────────────────────────────
# Домен Netlify. Несколько через запятую. * для разрешения всех (не для прода).
ALLOWED_ORIGINS=https://your-app.netlify.app

# ─── Кеш ────────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=60

# ─── Режим разработки ───────────────────────────────────────────────────────────
# true = тестовые данные без Google Sheets
# Тестовые пользователи: admin/admin123, employee1/emp123, CLIENT001/client123
USE_MOCK_DATA=false
