# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Google Sheets ────────────────────────────────────────────────────────────
# ID таблицы (из URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)
SPREADSHEET_ID=your_spreadsheet_id_here

# Вкладка с данными о посылках (обычно Scans!A:Z)
SHEET_RANGE=Scans!A:Z

# Вкладка с отправками (создать вручную в таблице)
SHIPMENTS_SHEET_NAME=Shipments

# Локальный запуск: путь к JSON-файлу Service Account
GOOGLE_KEY_FILE=./credentials/service-account.json

# Облачный деплой (Railway): вставить весь JSON одной строкой
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n..."}

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Домен Netlify (после деплоя). Можно несколько через запятую.
# Используй * для разрешения всех источников (не рекомендуется в продакшне)
ALLOWED_ORIGINS=https://your-app.netlify.app

# ─── Кеш ──────────────────────────────────────────────────────────────────────
# Время кеша в секундах (данные обновляются раз в N секунд)
CACHE_TTL_SECONDS=60

# ─── Режим разработки ─────────────────────────────────────────────────────────
# true = тестовые данные без Google Sheets
USE_MOCK_DATA=false
